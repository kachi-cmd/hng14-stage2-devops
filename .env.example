# =============================================================================
# .env.example
# Copy this file to .env and fill in real values before running the stack.
#   cp .env.example .env
#
# .env is listed in .gitignore and must NEVER be committed to the repository.
# =============================================================================

# --- Application ---
APP_ENV=production

# --- Image tagging (used by docker-compose and the CI pipeline) ---
# In CI this is set to the git SHA. Locally, "latest" is fine.
IMAGE_TAG=latest

# --- Frontend ---
# The host port the frontend will be accessible on
FRONTEND_PORT=3000

# --- Resource limits (Docker deploy constraints) ---
# Adjust these based on your host machine's available resources.
REDIS_CPU_LIMIT=0.25
REDIS_MEMORY_LIMIT=128M

API_CPU_LIMIT=0.5
API_MEMORY_LIMIT=256M

WORKER_CPU_LIMIT=0.5
WORKER_MEMORY_LIMIT=256M

FRONTEND_CPU_LIMIT=0.25
FRONTEND_MEMORY_LIMIT=128M
